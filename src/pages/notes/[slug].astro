---
import { getCollection, render } from 'astro:content';
import PageShell from '../../components/PageShell.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { sitePath } from '../../data/site';

export async function getStaticPaths() {
  const notes = await getCollection('notes', ({ data }) => !data.draft);

  return notes.map((note) => ({
    params: { slug: note.id },
    props: { note }
  }));
}

const { note } = Astro.props;
const { Content } = await render(note);

const formatDate = (date: Date) =>
  `${date.getFullYear()}.${String(date.getMonth() + 1).padStart(2, '0')}.${String(date.getDate()).padStart(2, '0')}`;
---

<BaseLayout title={`${note.data.title} | Hemisphere`} description={note.data.excerpt}>
  <PageShell
    eyebrow="Note"
    title={note.data.title}
    description={note.data.excerpt}
    activePath="/notes"
  >
    <article class="mx-auto w-full max-w-3xl px-5 py-10 sm:px-8">
      <div class="mb-8 flex flex-wrap items-center gap-3 border-b border-white/10 pb-5">
        <time datetime={note.data.date.toISOString()} class="font-mono text-xs text-stone-500">
          {formatDate(note.data.date)}
        </time>
        <span class="rounded border border-white/10 px-2 py-1 font-mono text-[11px] uppercase tracking-[0.14em] text-stone-500">
          {note.data.tag}
        </span>
        <a href={sitePath('/notes')} class="ml-auto font-mono text-xs text-stone-500 transition hover:text-signal-cyan">
          Back to notes
        </a>
      </div>
      <div class="note-body">
        <Content />
      </div>
    </article>
  </PageShell>
</BaseLayout>
